SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# ─── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULE_HOUR=19
SCHEDULE_MINUTE=0
# Find your timezone: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
SCHEDULE_TIMEZONE=America/Chicago

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PATH=./data/opportunities.db

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
